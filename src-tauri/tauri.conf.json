{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Thore",
  "version": "0.2.0",
  "identifier": "org.aenaon.thore",
  "build": {
    "frontendDist": "../renderer"
  },
  "app": {
    "windows": [
      {
        "title": "Thore",
        "width": 1100,
        "height": 760,
        "minWidth": 340,
        "minHeight": 280,
        "backgroundColor": "#081527"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
